{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "Anime": {
      "type": "object",
      "minItems": 1,
      "properties": {
        "id": {
          "type": "integer"
        },
        "titulo": {
          "type": "string"
        },
        "genero": {
          "type": "string"
        },
        "AñoEmision": {
          "type": "integer"
        },
        "Episodios": {
          "type": "integer"
        },
        "personajes": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "titulo"
      ],
      "additionalProperties": false
        },
    "personajes": {
      "type": "array",
      "minItems": 1
    },
    "nom": {
      "type": "string"
    },
    "rol": {
      "type": "string"
    },
    "edad": {
      "type": "integer"
    },
    "descripcio": {
      "type": "string"
    }
  }
    }
